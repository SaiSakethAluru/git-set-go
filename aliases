[alias]
    # Inspect the aliases Git can see in the current context.
    # Optionally pass a single alias name to look up just that one.
    alias = "!f() { \
        if [ \"$#\" -eq 0 ]; then \
            git config --get-regexp '^alias\\.' || echo 'No aliases found.'; \
        else \
            value=$(git config --get \"alias.$1\" || true); \
            if [ -n \"$value\" ]; then \
                printf 'alias.%s=%s\\n' \"$1\" \"$value\"; \
            else \
                echo \"No alias named '$1' found.\"; \
            fi; \
        fi; \
    }; f"

    # Simple shortcuts for frequently used Git commands.
    br = branch
    cm = commit
    co = checkout
    cp = cherry-pick
    d = diff
    l = log
    last = show HEAD
    poh = push origin HEAD
    st = status

    # Drop the most recent commit while keeping all changes staged.
    # This is useful when the commit should be redone but the work itself is fine.
    undo = reset --soft HEAD~1

    # Clear all stashes after an explicit y/n confirmation, or drop one stash by index.
    # `git sd 2` removes `stash@{2}` directly without doing a full clear.
    sd = "!f() { \
        if [ \"$#\" -eq 0 ]; then \
            printf 'Drop all stashes? [y/N] '; \
            read answer; \
            case \"$answer\" in \
                y|Y) git stash clear ;; \
                *) echo 'Aborted.' ;; \
            esac; \
        else \
            git stash drop \"stash@{$1}\"; \
        fi; \
    }; f"

    # Pop the latest stash by default, or pop a specific stash by numeric index.
    # `git sp 2` applies and drops `stash@{2}`.
    sp = "!f() { \
        if [ \"$#\" -eq 0 ]; then \
            git stash pop; \
        else \
            git stash pop \"stash@{$1}\"; \
        fi; \
    }; f"

    # Stash current changes, optionally using the provided arguments as the stash message.
    # `git ss` uses Git's default message, while `git ss my_msg` stores a custom one.
    ss = "!f() { \
        if [ \"$#\" -eq 0 ]; then \
            git stash push; \
        else \
            git stash push -m \"$*\"; \
        fi; \
    }; f"

    # Update your current branch from its upstream remote's default branch when available.
    # Falls back safely when needed, then merges with --no-edit after returning to your branch.
    up = "!f() { \
        branch=$(git symbolic-ref --quiet --short HEAD) || exit 1; \
        remote=$(git config --get \"branch.$branch.remote\" || true); \
        if [ -z \"$remote\" ]; then \
            remotes=$(git remote); \
            set -- $remotes; \
            if [ \"$#\" -eq 1 ]; then \
                remote=$1; \
            elif [ \"$#\" -gt 1 ]; then \
                echo 'No upstream remote configured for the current branch.' >&2; \
                echo 'Set an upstream or use a repo with a single remote.' >&2; \
                exit 1; \
            fi; \
        fi; \
        default_branch=''; \
        if [ -n \"$remote\" ]; then \
            remote_head=$(git symbolic-ref --quiet --short \"refs/remotes/$remote/HEAD\" 2>/dev/null || true); \
            if [ -n \"$remote_head\" ]; then \
                default_branch=${remote_head#\"$remote/\"}; \
            fi; \
        fi; \
        if [ -z \"$default_branch\" ]; then \
            if git show-ref --verify --quiet refs/heads/main; then \
                default_branch=main; \
            elif git show-ref --verify --quiet refs/heads/master; then \
                default_branch=master; \
            else \
                echo 'Could not determine the default branch for update.' >&2; \
                exit 1; \
            fi; \
        fi; \
        git checkout \"$default_branch\" && \
        git pull ${remote:+\"$remote\"} \"$default_branch\" && \
        git checkout \"$branch\" && \
        git merge --no-edit \"$default_branch\"; \
    }; f"
